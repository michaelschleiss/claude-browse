#!/usr/bin/env python3
"""Browse Claude Code conversation history.

Usage:
  claude-browse              # pick from recent conversations in current project
  claude-browse <file.jsonl> # browse a specific conversation file
  claude-browse --all        # pick from all projects

Navigate: j/k (older/newer), d/u (scroll down/up), s (select), x (export),
          t (trim bloat), T (trim all), q (quit)
"""

import json, sys, os, tty, termios, shutil, argparse, uuid
from pathlib import Path
from datetime import datetime

CLAUDE_DIR = Path.home() / '.config' / 'claude' / 'projects'

# Fields in toolUseResult that are large and not needed for conversation context
BLOAT_FIELDS = {'originalFile'}


def cwd_to_project_dir(cwd=None):
    """Find the Claude project config dir for a working directory."""
    cwd = cwd or os.getcwd()

    # Try exact encoding first (replace / with -)
    encoded = cwd.replace('/', '-')
    exact = CLAUDE_DIR / encoded
    if exact.exists():
        return exact

    # Normalize: replace both / and _ with - and find match
    if CLAUDE_DIR.exists():
        normalized = cwd.replace('/', '-').replace('_', '-').lower()
        for d in CLAUDE_DIR.iterdir():
            if not d.is_dir():
                continue
            if d.name.replace('_', '-').lower() == normalized:
                return d

    # Also try parent dirs (maybe user is in a subdirectory)
    if CLAUDE_DIR.exists():
        parts = cwd.rstrip('/').split('/')
        for i in range(len(parts), 0, -1):
            parent = '/'.join(parts[:i])
            normalized = parent.replace('/', '-').replace('_', '-').lower()
            for d in CLAUDE_DIR.iterdir():
                if not d.is_dir():
                    continue
                if d.name.replace('_', '-').lower() == normalized:
                    return d

    return exact


def list_conversations(project_dir):
    """List JSONL files sorted by modification time (newest first)."""
    files = sorted(project_dir.glob('*.jsonl'), key=lambda f: f.stat().st_mtime, reverse=True)
    return files


def peek_conversation(path):
    """Get first user message and message count for preview."""
    first_user = None
    assistant_count = 0
    try:
        with open(path) as f:
            for line in f:
                obj = json.loads(line.strip())
                t = obj.get('type')
                if t == 'user' and first_user is None:
                    msg = obj.get('message', {})
                    content = msg.get('content', [])
                    if isinstance(content, str):
                        first_user = content[:80]
                    elif isinstance(content, list):
                        for block in content:
                            if isinstance(block, dict) and block.get('type') == 'text':
                                first_user = block['text'][:80]
                                break
                elif t == 'assistant':
                    msg = obj.get('message', {})
                    content = msg.get('content', [])
                    if isinstance(content, list):
                        for block in content:
                            if isinstance(block, dict) and block.get('type') == 'text':
                                assistant_count += 1
                                break
    except Exception:
        pass
    return first_user or '(empty)', assistant_count


def pick_conversation(files):
    """Interactive picker for conversation files."""
    if not files:
        print("No conversations found.")
        sys.exit(1)

    # show up to 15 most recent
    files = files[:15]
    previews = []
    for f in files:
        mtime = datetime.fromtimestamp(f.stat().st_mtime)
        first_msg, n_answers = peek_conversation(f)
        previews.append((f, mtime, first_msg, n_answers))

    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    selected = 0

    def draw():
        cols, rows = shutil.get_terminal_size((80, 24))
        os.system('clear')
        print(f"\033[1mSelect a conversation\033[0m  [\033[33mj/k\033[0m move] [\033[33mENTER\033[0m select] [\033[33mq\033[0m quit]")
        print(f"\033[36m{'─' * cols}\033[0m")
        for i, (f, mtime, first_msg, n_answers) in enumerate(previews):
            marker = '\033[1;33m▸\033[0m' if i == selected else ' '
            date_str = mtime.strftime('%Y-%m-%d %H:%M')
            clean = first_msg.strip()
            if clean.startswith('<system'):
                clean = '(system message)'
            trunc = clean[:cols - 40]
            highlight = '\033[1m' if i == selected else '\033[2m'
            print(f"  {marker} {highlight}{date_str}  ({n_answers:2d} msgs)  {trunc}\033[0m")

    try:
        tty.setcbreak(fd)
        draw()
        while True:
            ch = sys.stdin.read(1)
            if ch == 'q':
                termios.tcsetattr(fd, termios.TCSADRAIN, old)
                os.system('clear')
                sys.exit(0)
            elif ch == 'j' and selected < len(previews) - 1:
                selected += 1
                draw()
            elif ch == 'k' and selected > 0:
                selected -= 1
                draw()
            elif ch in ('\r', '\n'):
                termios.tcsetattr(fd, termios.TCSADRAIN, old)
                return previews[selected][0]
    except Exception:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
        raise


def fmt_size(n):
    """Format byte count as human-readable string."""
    if n < 1024:
        return f"{n}B"
    elif n < 1024 * 1024:
        return f"{n / 1024:.0f}K"
    else:
        return f"{n / (1024 * 1024):.1f}M"


def compute_exchange_sizes(raw_lines, exchanges):
    """Compute raw size and bloat size for each exchange.

    Returns list of (total_size, bloat_size) tuples, one per exchange.
    """
    sizes = []
    for ex in exchanges:
        total = 0
        bloat = 0
        for li in ex['line_indices']:
            line = raw_lines[li]
            total += len(line)
            try:
                obj = json.loads(line)
                tur = obj.get('toolUseResult', {})
                for field in BLOAT_FIELDS:
                    val = tur.get(field, '')
                    if val:
                        bloat += len(json.dumps(val))
            except Exception:
                pass
        sizes.append((total, bloat))
    return sizes


def trim_exchange(raw_lines, exchanges, exchange_idx):
    """Strip bloat fields from toolUseResult in an exchange's raw lines.

    Modifies raw_lines in place. Returns bytes saved.
    """
    saved = 0
    for li in exchanges[exchange_idx]['line_indices']:
        line = raw_lines[li]
        try:
            obj = json.loads(line)
            tur = obj.get('toolUseResult')
            if not tur:
                continue
            trimmed = False
            for field in BLOAT_FIELDS:
                if field in tur and tur[field]:
                    saved += len(json.dumps(tur[field]))
                    tur[field] = ''
                    trimmed = True
            if trimmed:
                raw_lines[li] = json.dumps(obj)
        except Exception:
            pass
    return saved


def parse_conversation(path):
    """Parse JSONL into logical exchanges.

    Returns:
        raw_lines: list of raw JSONL strings
        exchanges: list of dicts with:
            - user_text: display text for the user prompt
            - assistant_text: display text for the assistant response
            - line_indices: list of indices into raw_lines for all JSONL entries
              that belong to this exchange (user, assistant, tool rounds, progress, etc.)
    """
    with open(path) as f:
        raw_lines = [line.strip() for line in f if line.strip()]

    parsed = []
    for line in raw_lines:
        parsed.append(json.loads(line))

    # Group into exchanges: each exchange starts at a user message that has text content
    # and includes everything until the next user message with text content.
    # We also track "preamble" lines (system, file-history-snapshot) before the first user msg.

    exchanges = []
    preamble_indices = []  # lines before first user text message
    current_user_text = None
    current_assistant_texts = []
    current_line_indices = []
    in_preamble = True

    for i, obj in enumerate(parsed):
        t = obj.get('type')

        # Check if this is a user message with actual text content
        is_user_text = False
        user_text = None
        if t == 'user':
            msg = obj.get('message', {})
            content = msg.get('content', [])
            texts = []
            if isinstance(content, str):
                texts.append(content)
            elif isinstance(content, list):
                for block in content:
                    if isinstance(block, dict) and block.get('type') == 'text':
                        texts.append(block['text'])
            if texts:
                is_user_text = True
                user_text = '\n'.join(texts)

        if is_user_text:
            in_preamble = False
            # Save previous exchange if exists
            if current_user_text is not None and current_assistant_texts:
                exchanges.append({
                    'user_text': current_user_text,
                    'assistant_text': '\n'.join(current_assistant_texts),
                    'line_indices': current_line_indices[:],
                })
            elif current_user_text is not None:
                # user message with no assistant response yet — still save
                exchanges.append({
                    'user_text': current_user_text,
                    'assistant_text': '(no response)',
                    'line_indices': current_line_indices[:],
                })
            # Start new exchange
            current_user_text = user_text
            current_assistant_texts = []
            current_line_indices = [i]
        elif in_preamble:
            preamble_indices.append(i)
        else:
            # Part of current exchange
            current_line_indices.append(i)

            # Extract assistant text for display
            if t == 'assistant':
                msg = obj.get('message', {})
                content = msg.get('content', [])
                if isinstance(content, list):
                    for block in content:
                        if isinstance(block, dict) and block.get('type') == 'text':
                            current_assistant_texts.append(block['text'])

    # Save last exchange
    if current_user_text is not None and current_assistant_texts:
        exchanges.append({
            'user_text': current_user_text,
            'assistant_text': '\n'.join(current_assistant_texts),
            'line_indices': current_line_indices[:],
        })

    return raw_lines, preamble_indices, exchanges


def export_jsonl(raw_lines, preamble_indices, exchanges, selected_set, source_path, trim=True):
    """Export selected exchanges as a new JSONL file.

    If trim=True, strips bloat fields from toolUseResult before writing.
    """
    project_dir = source_path.parent
    new_session_id = str(uuid.uuid4())
    new_path = project_dir / f"{new_session_id}.jsonl"

    # Collect all line indices to include: preamble + selected exchanges
    include_indices = set(preamble_indices)
    for idx in selected_set:
        for li in exchanges[idx]['line_indices']:
            include_indices.add(li)

    # Rewrite lines with new session ID
    total_saved = 0
    with open(new_path, 'w') as f:
        for i, line in enumerate(raw_lines):
            if i not in include_indices:
                continue
            obj = json.loads(line)
            # Update session ID so Claude Code treats it as a new session
            if 'sessionId' in obj:
                obj['sessionId'] = new_session_id
            # Strip bloat if requested
            if trim:
                tur = obj.get('toolUseResult')
                if tur:
                    for field in BLOAT_FIELDS:
                        if field in tur and tur[field]:
                            total_saved += len(json.dumps(tur[field]))
                            tur[field] = ''
            f.write(json.dumps(obj) + '\n')

    return new_path, new_session_id, total_saved


def browse(raw_lines, preamble_indices, exchanges, source_path):
    if not exchanges:
        print("No message pairs found.")
        sys.exit(1)

    idx = len(exchanges) - 1
    scroll = 0
    selected = set()
    trimmed = set()  # exchanges that have been trimmed
    sizes = compute_exchange_sizes(raw_lines, exchanges)
    total_saved = 0
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)

    def show():
        nonlocal scroll
        cols, rows = shutil.get_terminal_size((80, 24))
        os.system('clear')
        n = len(exchanges)
        n_sel = len(selected)
        ex_size, ex_bloat = sizes[idx]

        sel_indicator = f"  \033[1;35m{n_sel} selected\033[0m" if n_sel else ""
        is_sel = " \033[1;35m★\033[0m" if idx in selected else ""
        is_trimmed = " \033[1;32m✂\033[0m" if idx in trimmed else ""

        # Size indicator with bloat warning
        size_str = fmt_size(ex_size)
        if ex_bloat > 10000:
            bloat_str = f" \033[1;31m({fmt_size(ex_bloat)} bloat)\033[0m"
        elif ex_bloat > 0:
            bloat_str = f" \033[33m({fmt_size(ex_bloat)} bloat)\033[0m"
        else:
            bloat_str = ""

        saved_str = f"  \033[1;32msaved {fmt_size(total_saved)}\033[0m" if total_saved else ""

        header = (
            f"  \033[1m{idx+1}/{n}\033[0m{is_sel}{is_trimmed}"
            f"  {size_str}{bloat_str}{sel_indicator}{saved_str}"
        )
        keys = (
            f"  [\033[33mj/k\033[0m nav] [\033[33md/u\033[0m scroll]"
            f" [\033[33ms\033[0m select] [\033[33mt\033[0m trim] [\033[33mT\033[0m trim all]"
            f" [\033[33mx\033[0m export] [\033[33mq\033[0m quit]"
        )
        print(f"\033[36m{'─' * cols}\033[0m")
        print(header)
        print(keys)
        print(f"\033[36m{'─' * cols}\033[0m")

        ex = exchanges[idx]
        user = ex['user_text']
        assistant = ex['assistant_text']

        output_lines = []
        output_lines.append(f"\033[1;32m▶ You:\033[0m")
        for l in (user or '').split('\n'):
            stripped = l.strip()
            if stripped.startswith('<system-reminder>') or stripped.startswith('</system-reminder>'):
                continue
            output_lines.append(f"  \033[32m{l}\033[0m")
        output_lines.append('')
        output_lines.append(f"\033[1;34m◀ Claude:\033[0m")
        for l in assistant.split('\n'):
            output_lines.append(f"  {l}")

        avail = rows - 5
        visible = output_lines[scroll:scroll + avail]
        for l in visible:
            print(l)

        return len(output_lines)

    try:
        total_lines = show()
        tty.setcbreak(fd)
        while True:
            ch = sys.stdin.read(1)
            if ch == 'q':
                break
            elif ch == 'j' and idx > 0:
                idx -= 1
                scroll = 0
                total_lines = show()
            elif ch == 'k' and idx < len(exchanges) - 1:
                idx += 1
                scroll = 0
                total_lines = show()
            elif ch == 'd':
                _, rows = shutil.get_terminal_size((80, 24))
                avail = rows - 5
                scroll = min(scroll + avail // 2, max(0, total_lines - avail))
                show()
            elif ch == 'u':
                _, rows = shutil.get_terminal_size((80, 24))
                avail = rows - 5
                scroll = max(0, scroll - avail // 2)
                show()
            elif ch == 's':
                if idx in selected:
                    selected.remove(idx)
                else:
                    selected.add(idx)
                show()
            elif ch == 't':
                # Trim bloat from current exchange
                _, bloat = sizes[idx]
                if bloat > 0 and idx not in trimmed:
                    saved = trim_exchange(raw_lines, exchanges, idx)
                    total_saved += saved
                    trimmed.add(idx)
                    sizes[idx] = (sizes[idx][0] - saved, 0)
                show()
            elif ch == 'T':
                # Trim all exchanges with bloat
                for i in range(len(exchanges)):
                    _, bloat = sizes[i]
                    if bloat > 0 and i not in trimmed:
                        saved = trim_exchange(raw_lines, exchanges, i)
                        total_saved += saved
                        trimmed.add(i)
                        sizes[i] = (sizes[i][0] - saved, 0)
                show()
            elif ch == 'x':
                if not selected:
                    # flash message
                    termios.tcsetattr(fd, termios.TCSADRAIN, old)
                    print("\033[1;31mNo messages selected. Use 's' to select first.\033[0m")
                    import time; time.sleep(1)
                    tty.setcbreak(fd)
                    show()
                    continue
                # Export (always trims bloat from exported file)
                termios.tcsetattr(fd, termios.TCSADRAIN, old)
                new_path, new_session_id, export_saved = export_jsonl(
                    raw_lines, preamble_indices, exchanges, selected, source_path, trim=True
                )
                os.system('clear')
                n_sel = len(selected)
                orig_size = sum(len(raw_lines[li]) for idx in selected for li in exchanges[idx]['line_indices'])
                new_size = new_path.stat().st_size
                print(f"\033[1;32mExported {n_sel} exchanges to:\033[0m")
                print(f"  {new_path}")
                if export_saved:
                    print(f"  \033[32mTrimmed {fmt_size(export_saved)} of bloat (originalFile data)\033[0m")
                print()
                print(f"\033[1mResume with:\033[0m")
                print(f"  claude --resume {new_session_id}")
                print()
                return
    finally:
        try:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
        except Exception:
            pass


def main():
    parser = argparse.ArgumentParser(description='Browse Claude Code conversation history')
    parser.add_argument('file', nargs='?', help='Specific JSONL file to browse')
    parser.add_argument('--all', action='store_true', help='Pick from all projects')
    parser.add_argument('--trim', action='store_true',
                        help='Trim bloat (originalFile) from all exchanges and rewrite file in-place')
    args = parser.parse_args()

    if args.file:
        path = Path(args.file)
    elif args.all:
        all_files = sorted(CLAUDE_DIR.glob('*/*.jsonl'), key=lambda f: f.stat().st_mtime, reverse=True)
        path = pick_conversation(all_files)
    else:
        project_dir = cwd_to_project_dir()
        if not project_dir.exists():
            print(f"No Claude project found for {os.getcwd()}")
            print(f"Expected: {project_dir}")
            sys.exit(1)
        files = list_conversations(project_dir)
        if len(files) == 1:
            path = files[0]
        else:
            path = pick_conversation(files)

    # Non-interactive trim mode: rewrite the file in place
    if args.trim:
        raw_lines, preamble_indices, exchanges = parse_conversation(path)
        total_saved = 0
        n_trimmed = 0
        for i in range(len(exchanges)):
            saved = trim_exchange(raw_lines, exchanges, i)
            if saved > 0:
                total_saved += saved
                n_trimmed += 1
        if total_saved > 0:
            with open(path, 'w') as f:
                for line in raw_lines:
                    f.write(line + '\n')
            print(f"Trimmed {n_trimmed} exchanges, saved {fmt_size(total_saved)}")
            print(f"  {path}")
        else:
            print("No bloat found to trim.")
        return

    raw_lines, preamble_indices, exchanges = parse_conversation(path)
    browse(raw_lines, preamble_indices, exchanges, path)


if __name__ == '__main__':
    main()
